{
  "source": "input/processed/figma-q1-fy26.png",
  "outputDir": "data/assets/icon-references/figma/crops",
  "validationSheetDir": "data/assets/icon-references/figma/validation-sheets",
  "report": "../crop-report.json",
  "background": [242, 242, 242],
  "backgroundRemoval": {
    "enabled": true,
