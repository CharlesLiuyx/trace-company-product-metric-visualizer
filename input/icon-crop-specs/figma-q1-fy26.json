  "crops": [
    {
      "key": "figma-company-app-icon",
      "output": "company-app-icon.png",
      "searchBox": { "x": 735, "y": 225, "width": 290, "height": 275 },
      "cropBox": { "x": 735, "y": 225, "width": 290, "height": 280 },
      "threshold": 18,
      "minComponentArea": 35,
      "padding": 18,
      "validation": {
        "borderBand": 3,
        "maxCenterOffset": 0.08,
        "maxForbiddenForegroundPixels": 0
